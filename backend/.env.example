# ============================================================
#  RDWeb-Moderno — Configuración del servidor
#  Copia este archivo como .env y ajusta los valores
# ============================================================

# --- Servidor Express ---
PORT=3000
NODE_ENV=development

# --- JWT ---
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_en_produccion
JWT_EXPIRES_IN=8h

# --- Active Directory / LDAP ---
# Hostname o IP de tu Domain Controller
LDAP_URL=ldap://dc01.lab-mh.local
# Base DN de tu dominio
LDAP_BASE_DN=DC=lab-mh,DC=local
# Dominio NetBIOS (se antepone al usuario: DOMINIO\usuario)
AD_DOMAIN=LAB-MH

# Cuenta de servicio AD (solo necesitas permisos de lectura en el directorio)
# Úsala en formato UPN:  usuario@dominio.local
# O en formato DN:       CN=svc-rdweb,OU=Cuentas de Servicio,DC=lab-mh,DC=local
AD_SERVICE_USER=svc-rdweb@lab-mh.local
AD_SERVICE_PASS=CambiaEstoEnProduccion!

# --- RD Connection Broker ---
RDCB_SERVER=SRV-APPS.LAB-MH.LOCAL

# --- RD Gateway ---
RDGATEWAY_HOSTNAME=rdgateway.lab-mh.local

# --- Modo simulación ---
# Poner en "true" para usar datos fake (sin AD ni RDCB reales)
SIMULATION_MODE=true
SIMULATION_USER=administrador
SIMULATION_PASS=Admin1234!
